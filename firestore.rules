rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Groups
    match /groups/{groupId} {
      allow read: if request.auth != null && (resource == null || request.auth.uid in resource.data.memberIds);
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.memberIds;
    }
    
    // Invites
    match /invites/{inviteId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.senderId || request.auth.token.email == resource.data.receiverEmail);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.senderId || request.auth.token.email == resource.data.receiverEmail);
    }
  }
}
